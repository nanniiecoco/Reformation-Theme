{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'customer-main.js' | asset_url | script_tag }}
<div class="section-spacing">
	<div class="row">
		<div class="small-12 columns">
			<div class="myaccount--header">
				<h1 class="myaccount--title">{{ 'customer.account.title' | t }}</h1>
				<p>
					<a href="{{ routes.account_logout_url }}" title="{{ 'customer.account.log_out' | t | escape }}" class="myaccount--link">
		      	{% render 'svg-icons' with 'thb-log-out' %}
		      	<span class="text-button">{{ 'customer.account.log_out' | t }}</span>
		    	</a>
				</p>
			</div>
		</div>
	</div>
	<div class="row">
	  <div class="small-12 large-8 columns myaccount-content">
			{% include 'returnprime_script' %}
			<h4>
				{{ 'customer.size_preference.title' | t }}
				{% if customer.metafields.custom.reference_variant.value %}
				<small class="edit-wrap">
					<span class="btn-edit">{% render 'svg-icons' with 'thb-edit' %}{{ 'customer.size_preference.edit' | t }}</span>
				</small>
				<small class="save-wrap hidden">
					<span class="btn-save">{% render 'svg-icons' with 'thb-check' %}{{ 'customer.size_preference.save' | t }}</span>
					<span class="btn-cancel">{% render 'svg-icons' with 'thb-cancel' %}{{ 'customer.size_preference.cancel' | t }}</span>
				</small>
				{% endif %}
			</h4>
			{% comment %} list item from customer metafield json "Reference Variants" {% endcomment %}
			{% if customer.metafields.custom.reference_variant.value %}
			<table class="size-preference-table">
				<thead>
					<tr>
						<th>{{ 'customer.size_preference.product_category' | t }}</th>
						<th>{{ 'customer.size_preference.size' | t }}</th>
						<th>{{ 'customer.size_preference.size_saved_product' | t }}</th>
					</tr>
				</thead>
				<tbody>
				{% assign sizes_array = customer.metafields.custom.reference_variant.value | parse_json %}
				{% for item in sizes_array %}
                    <tr>
                        <td>{{ item.category }}</td>
                        <td>
                            {% assign available_sizes = "XS, S, M, L, XL, XXL, XXXL" | split: ", " %}
                            {% assign preferred_size = item.size | downcase %}
                            <select class="select-size" name="size" disabled>
                                {% for size in available_sizes %}
                                    {% assign size_downcase = size | downcase %}
                                    <option value="{{ size }}" {% if size_downcase == preferred_size %}selected{% endif %}>
                                        {{ size }}
                                    </option>
                                {% endfor %}
                            </select>
                        </td>
                        <td>
                            {% if item['size saved product'] %}
                                <a href="{{ item['size saved product'] }}">{{ item['size saved product'] }}</a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
				</tbody>
			</table>
			{% else %}
				<p>{{ 'customer.size_preference.data_empty' | t }}</p>
			{% endif %}

			<h4>{{ 'customer.orders.title' | t }}</h4>
			{% paginate customer.orders by 20 %}
	      {%- if customer.orders.size > 0 -%}
		      <table class="no-borders">
		      	<thead>
		      		<tr>
								<th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
	              <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
	              <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
	              <th id="ColumnFulfillment" scope="col" role="columnheader">{{ 'customer.orders.fulfillment_status' | t }}</th>
	              <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
					<th>Return</th>
		        </thead>
		        <tbody role="rowgroup">
		          {% for order in customer.orders %}
							<tr role="row">
	              <td
	                id="RowOrder"
	                role="cell"
	                headers="ColumnOrder"
	                data-label="{{ 'customer.orders.order_number' | t }}"
	              >
	                <a href="{{ order.customer_url }}" aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}">
	                  {{ order.name }}
	                </a>
	              </td>
	              <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
	                {{ order.created_at | time_tag: format: 'date' }}
	              </td>
	              <td headers="RowOrder ColumnPayment" role="cell" data-label="{{ 'customer.orders.payment_status' | t }}">
	                {{ order.financial_status_label }}
	              </td>
	              <td headers="RowOrder ColumnFulfillment" role="cell" data-label="{{ 'customer.orders.fulfillment_status' | t }}">
	                {{ order.fulfillment_status_label }}
	              </td>
	              <td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
	                {{ order.total_price | money_with_currency }}</td>
					<td data-order_name={{order.id}} data-label="Return" class="return__exchange">
						{% if order.fulfillment_status == 'fulfilled' %}
							<button class="js-return-exchange {% if order.fulfillment_status != 'fulfilled' %} disabled{% endif %}" data-order="{{ order.name }}" data-customer="{{ customer.email }}">Return</button>
						{% else %}
							<p class="js-return-exchange disabled"> Not Available </p>
						{% endif %}
					</td>
	            </tr>
				  {% endfor %}
		        </tbody>
		      </table>
				{%- else -%}
	       <p>{{ 'customer.orders.none' | t }}</p>
	     	{%- endif -%}
				{% render 'pagination', paginate: paginate, pagination_type: 'paginated' %}
		 {% endpaginate %}
	  </div>
	  <div class="small-12 large-4 columns myaccount-sidebar">
	    <h4>{{ 'customer.account.details' | t }}</h4>
			{% if customer.default_address %}
			<label>{{ 'customer.account.default_address' | t }}</label>
			<address>
				{{ customer.default_address.address1 }}<br />
			{% if customer.default_address.address2 != "" %}
				{{ customer.default_address.address2 }}<br />
			{% endif %}
				{{ customer.default_address.city }}, {% if address.default_address.province_code %}{{ customer.default_address.province_code }}, {% endif %}{{ customer.default_address.country }}<br />
				{{ customer.default_address.zip }}<br />
				{{ customer.default_address.phone }}
			</address>
			{% endif %}
			<a href="{{ routes.account_addresses_url }}" class="text-button">
				{{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
			</a>
		  <div class="shopify-account right-layout">
			  {% render 'cap' %}
		  </div>
	  </div>
	</div>
</div>

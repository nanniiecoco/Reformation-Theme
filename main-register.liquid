{{ 'login-register.css' | asset_url | stylesheet_tag }}
{%- liquid
	assign section_image = section.settings.section_image
-%}
{%- if section_image -%}
	<div class="thb-login-page-wrapper">
		{%- liquid
			assign master_width = section_image.src.width | append: 'x' | append: section_image.src.height

			render 'responsive-image', image: section_image, sizes: master_width
		 -%}
{%- endif -%}
<div class="row">
	<div class="small-12 columns">
    <div class="thb-form-container">
      <div class="thb-register-form">
        {% form 'create_customer', novalidate: 'novalidate', class: 'register-form' %}
					<h4>{{ 'customer.login_page.create_account' | t }}</h4>
					<p>{{ 'customer.login_page.create_account_description' | t }}</p>
					{% if form.errors %}
					<div class="form-notification error">
						{% render 'svg-icons' with 'thb-error' %} {{ form.errors | default_errors }}
					</div>
					{% endif %}
					<div class="fields">
            <div class="field">
              <input id="RegisterForm-FirstName" type="text" name="customer[first_name]" class="full" value="{% if form.first_name %}{{ form.first_name }}{% endif %}" placeholder="{{ 'customer.login_page.first_name' | t }}" />
	            <label for="RegisterForm-FirstName">{{ 'customer.login_page.first_name' | t }}</label>
            </div>
            <div class="field">
              <input id="RegisterForm-LastName" type="text" name="customer[last_name]" class="full" value="{% if form.last_name %}{{ form.last_name }}{% endif %}" placeholder="{{ 'customer.login_page.last_name' | t }}" />
	            <label for="RegisterForm-LastName">{{ 'customer.login_page.last_name' | t }}</label>
            </div>
					</div>
          <div class="field">
            <input type="email" name="customer[email]" id="RegisterForm-email" class="full {% if form.errors contains 'email' %}invalid{% endif %}" value="" placeholder="{{ 'customer.login_page.email' | t }}" />
            <label for="email">{{ 'customer.login_page.email' | t }}</label>
          </div>
          <div class="field">
            <input id="RegisterForm-password" type="password" name="customer[password]" class="full" value="" placeholder="{{ 'customer.login_page.password' | t }}" />
            <label for="RegisterForm-password">{{ 'customer.login_page.password' | t }}</label>
          </div>
          {%- if form.errors contains 'password' -%}
            <span id="RegisterForm-password-error" class="form__message">
              <span class="svg-wrapper">
                {{- 'icon-error.svg' | inline_asset_content -}}
              </span>
              {{ form.errors.translated_fields.password | capitalize }}
              {{ form.errors.messages.password }}.
            </span>
          {%- endif -%}
          <div class="fields fields--phone">
            <div class="field">
              <select name="customer[note][isd_code]" class="full" id="isd_code-select">
                <option value="66" selected>🇹🇭 +66</option>
                <option value="1">🇺🇸 +1</option>
                <option value="44">🇬🇧 +44</option>
                <option value="84">🇻🇳 +84</option>
                <option value="81">🇯🇵 +81</option>
                <option value="86">🇨🇳 +86</option>
                <option value="61">🇦🇺 +61</option>
                <option value="49">🇩🇪 +49</option>
                <option value="33">🇫🇷 +33</option>
                <option value="82">🇰🇷 +82</option>
                <option value="852">🇭🇰 +852</option>
                <option value="65">🇸🇬 +65</option>
                <option value="62">🇮🇩 +62</option>
                <option value="91">🇮🇳 +91</option>
                <option value="7">🇷🇺 +7</option>
                <option value="60">🇲🇾 +60</option>
                <option value="63">🇵🇭 +63</option>
                <option value="34">🇪🇸 +34</option>
                <option value="39">🇮🇹 +39</option>
                <option value="886">🇹🇼 +886</option>
                <!-- Add more countries as needed -->
              </select>
              <label for="isd_code">{{ 'customer.login_page.isd_code' | t }}</label>
            </div>
            <div class="field">
              <input type="tel" name="customer[note][phone]" class="full input--phone" value="{{ form.phone }}" placeholder="{{ 'customer.login_page.phone' | t }}" />
              <label for="phone">{{ 'customer.login_page.phone' | t }}</label>
            </div>
          </div>
          <button type="submit" class="button full"><span>{{ 'customer.login_page.submit_register' | t }}</span></button>
        {% endform %}
				<div class="switch-login-section">
					{{ 'customer.login_page.already_have_an_account' | t }} <a href="{{ routes.account_login_url }}" class="text-button">{{ 'customer.login_page.login' | t }}</a>
				</div>
      </div>
    </div>
  </div>
</div>
{%- if section_image -%}
	</div>
{%- endif -%}
{% schema %}
{
  "name": "Register",
  "tag": "section",
  "class": "section-customer-register",
	"settings": [
		{
			"type": "image_picker",
			"id": "section_image",
			"label": "Main image"
		}
	]
}
{% endschema %}

<script src="{{ 'register.js' | asset_url }}" defer="defer"></script>

<script>
    // Initialize localstorage, which is used to add flag that the form is from register page
    localStorage.setItem("requestFromRegisterForm", 1);
    window.errorMessages = {
        firstNameRequired: "{{ 'customer.register.first_name_required' | t }}",
        lastNameRequired: "{{ 'customer.register.last_name_required' | t }}",
        emailRequired: "{{ 'customer.register.email_required' | t }}",
        emailInvalid: "{{ 'customer.register.email_invalid' | t }}",
        emailExists: "{{ 'customer.register.email_exists' | t }}",
        passwordRequired: "{{ 'customer.register.password_required' | t }}",
        isdCodeRequired: "{{ 'customer.register.isd_code_required' | t }}",
        phoneRequired: "{{ 'customer.register.phone_required' | t }}",
        phoneInvalid: "{{ 'customer.register.phone_invalid' | t }}",
        phoneLeadingZero: "{{ 'customer.register.phone_leading_zero' | t }}",
        phoneExists: "{{ 'customer.register.phone_exists' | t }}"
    };
</script>